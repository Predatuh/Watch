rules_version = '2';

// Hardened rules for Cute Notes. Apply these BEFORE sharing the app publicly
// (replace the temporary "test mode" rules). Test the app after applying — if
// anything breaks, the Firebase console shows which rule denied the request.
//
// Apply via: Firebase console -> Firestore -> Rules -> paste -> Publish
// (or `firebase deploy --only firestore:rules` with the Firebase CLI).

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Friend codes: anyone signed in can look one up (to add a friend), but you
    // can only claim a new code for your own uid, and codes are never changed.
    match /codes/{code} {
      allow get: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // User profile: read by any signed-in user (needed to resolve friends),
    // writable only by its owner.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;

      // Friends list: manage your own, or add yourself to someone else's list
      // (the mutual link created when you add a friend).
      match /friends/{friendId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if signedIn() && (request.auth.uid == uid || request.auth.uid == friendId);
      }
    }

    // Inbox: any signed-in user may drop a note in; only the owner reads/clears.
    match /notes/{uid}/inbox/{noteId} {
      allow create: if signedIn();
      allow read, delete: if signedIn() && request.auth.uid == uid;
      allow update: if false;
    }
  }
}
